{
  "name": "scrappd",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:start": "pnpm --filter @scrappd/supabase run db:start",
    "db:push": "pnpm --filter @scrappd/supabase run db:push",
    "gen:types": "pnpm --filter @scrappd/supabase run gen:types"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  }
}
