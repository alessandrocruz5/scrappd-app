# Supabase connection for the Expo app.
#
# These are read at build time by Expo. The EXPO_PUBLIC_ prefix is required so
# the values are inlined into the JS bundle and available via process.env.
# Copy this file to `apps/mobile/.env` and fill in the values for the target you
# are building against. `.env` is git-ignored — never commit real values.
#
# ----------------------------------------------------------------------------
# LIVE / hosted Supabase (project: gujldqovvhjbctzelark)
# ----------------------------------------------------------------------------
# This is what the published web build and the EAS native builds ship against.
#   EXPO_PUBLIC_SUPABASE_URL=https://gujldqovvhjbctzelark.supabase.co
#   EXPO_PUBLIC_SUPABASE_ANON_KEY=<anon/publishable key from Supabase dashboard>
#
# Get the URL + anon key from: Supabase Dashboard -> Project Settings -> API
# (the anon "public" key, or a modern `sb_publishable_...` key). The anon key is
# safe to embed in the client — RLS is what protects the data, not key secrecy.
#
# In CI / hosting, these are supplied as build-time env vars rather than a file:
#   * Vercel (web):  Project -> Settings -> Environment Variables
#   * EAS (native):  `eas.json` build profile `env`, or EAS project secrets
# See apps/mobile/README.md ("Environment variables") for details.
#
# ----------------------------------------------------------------------------
# LOCAL development (Docker stack via `pnpm --filter @scrappd/supabase db:start`)
# ----------------------------------------------------------------------------
# Copy the API URL + anon key printed by `db:start` (or run `supabase status`).
#
# IMPORTANT (physical device / Expo Go):
#   127.0.0.1 points at the phone itself, not your dev machine. Replace the host
#   with your computer's LAN IP (e.g. http://192.168.1.42:54321) so Expo Go on
#   the iPhone can reach the local Supabase stack.

EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
