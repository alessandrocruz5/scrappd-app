{
  "name": "mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Scrappd Expo (React Native) app. Talks to Supabase directly (auth, Postgres+RLS, storage).",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform all",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@scrappd/shared-types": "workspace:*",
    "@shopify/react-native-skia": "2.6.4",
    "@supabase/supabase-js": "^2.107.0",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~56.0.8",
    "expo-camera": "~56.0.7",
    "expo-constants": "~56.0.16",
    "expo-image-picker": "~56.0.15",
    "expo-linking": "~56.0.13",
    "expo-media-library": "~56.0.6",
    "expo-router": "~56.2.8",
    "expo-sharing": "~56.0.15",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~3.0.0",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "~5.1.0",
