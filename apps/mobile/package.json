  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "eslint": "^9.39.0",
    "eslint-config-expo": "~56.0.4",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "react-test-renderer": "19.2.3",
    "typescript": "~5.9.3"
